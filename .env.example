# Local development ports. Change either value when another project already uses it.
STORYVERSE_API_PORT=4310
STORYVERSE_WEB_PORT=4311

# Reserved for the PostgreSQL container added in T-003. The uncommon host port
# avoids the default 5432 used by many local projects; PostgreSQL still uses
# port 5432 inside the Docker network.
STORYVERSE_DB_PORT=55432
STORYVERSE_DB_BIND_ADDRESS=127.0.0.1
STORYVERSE_DB_NAME=storyverse
STORYVERSE_DB_USER=storyverse
STORYVERSE_DB_PASSWORD=storyverse_dev
DATABASE_URL=postgresql://storyverse:storyverse_dev@localhost:55432/storyverse

# local: no login prompt. account: first visit creates the NAS administrator.
STORYVERSE_AUTH_MODE=local

# Used to encrypt saved AI API keys. Replace with a long random value on NAS.
STORYVERSE_SECRET_KEY=change-this-before-enabling-saved-api-keys
STORYVERSE_UPLOAD_DIR=./data/uploads
STORYVERSE_GENERATION_TIMEOUT_MS=600000
STORYVERSE_AI_RETRY_ATTEMPTS=3
STORYVERSE_AI_RETRY_BASE_DELAY_MS=500
STORYVERSE_AI_MAX_OUTPUT_TOKENS=4096
STORYVERSE_AI_STRUCTURED_RETRY_ATTEMPTS=2

# Docker/NAS: leave empty to use the named volume. On a NAS, set an absolute
# persistent directory such as /volume1/docker/storyverse/postgres.
# STORYVERSE_DATA_DIR=/volume1/docker/storyverse/postgres
